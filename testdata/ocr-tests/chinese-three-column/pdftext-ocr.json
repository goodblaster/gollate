      "left": 0.5228821909583393,
      "width": 0.01960784330065354,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "和珍惜",
    "bounds": {
      "top": 0.3813254457591663,
      "left": 0.5424900342589929,
      "width": 0.05882352990196062,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
