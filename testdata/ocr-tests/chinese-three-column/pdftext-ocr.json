    "text": "环",
    "bounds": {
      "top": 0.4040527175394693,
      "left": 0.3856272878537643,
      "width": 0.01960784330065354,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "境",
    "bounds": {
      "top": 0.4040527175394693,
      "left": 0.4052351311544179,
      "width": 0.01960784330065354,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "不仅是我们这一代人",
    "bounds": {
      "top": 0.4040527175394693,
      "left": 0.42484297445507146,
      "width": 0.17647058970588195,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "的责任,更是确",
