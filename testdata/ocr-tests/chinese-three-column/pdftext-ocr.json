      "width": 0.03921568660130708,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "影响着社会的方方面面,",
    "bounds": {
      "top": 0.49496180466068146,
      "left": 0.11764705392156861,
      "width": 0.21568627630718912,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "重塑着我们与世界互动",
    "bounds": {
      "top": 0.5176890764409845,
      "left": 0.11764705392156861,
      "width": 0.1960784330065356,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "的",
    "bounds": {
      "top": 0.5176890764409845,
      "left": 0.31372548692810426,
      "width": 0.01960784330065354,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "方式。",
    "bounds": {
      "top": 0.5404163482212875,
      "left": 0.11764705392156861,
      "width": 0.058823529901960686,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "古代文明建造了令人惊叹",
