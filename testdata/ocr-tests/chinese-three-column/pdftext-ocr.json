      "width": 0.21568627630718906,
      "height": 0.01515151452020195
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "的各种工具、技能和深",
    "bounds": {
      "top": 0.1871966659690781,
      "left": 0.3856272878537643,
      "width": 0.19607843300653552,
      "height": 0.01515151452020195
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "刻",
    "bounds": {
      "top": 0.1871966659690781,
      "left": 0.5817057208602999,
      "width": 0.01960784330065354,
      "height": 0.01515151452020195
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "见解,从而为建设更美好",
    "bounds": {
      "top": 0.2099239377493811,
      "left": 0.3856272878537643,
      "width": 0.21568627630718906,
      "height": 0.01515151452020195
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "的未来做出贡献。",
    "bounds": {
      "top": 0.2326512095296841,
      "left": 0.3856272878537643,
      "width": 0.15686274640522846,
      "height": 0.01515151452020195
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
