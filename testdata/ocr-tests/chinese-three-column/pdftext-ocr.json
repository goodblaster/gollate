      "top": 0.4267799893197724,
      "left": 0.3856272878537643,
      "width": 0.13725490310457492,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "保后代子",
    "bounds": {
      "top": 0.4267799893197724,
      "left": 0.5228821909583393,
      "width": 0.07843137320261416,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "孙能够继续享受地球奇观",
    "bounds": {
      "top": 0.4495072611000754,
      "left": 0.3856272878537643,
      "width": 0.21568627630718906,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "的关键。",
    "bounds": {
      "top": 0.4722345328803785,
      "left": 0.3856272878537643,
      "width": 0.0784313732026142,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "有效的交流在不同文化、",
    "bounds": {
      "top": 0.5082193798658583,
      "left": 0.3856272878537643,
      "width": 0.21568627630718906,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "民族和国家之间架",
    "bounds": {
      "top": 0.5309466516461613,
      "left": 0.3856272878537643,
      "width": 0.15686274640522846,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "起了理",
    "bounds": {
      "top": 0.5309466516461613,
      "left": 0.5424900342589929,
      "width": 0.05882352990196062,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "解与合作的重要桥梁。语",
