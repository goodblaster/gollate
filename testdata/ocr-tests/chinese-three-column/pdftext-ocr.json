      "width": 0.13725490310457486,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "人发展的根本基础。通过",
    "bounds": {
      "top": 0.8159845185574618,
