      "width": 0.21568627630718912,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "力,也见证了人类文明的",
    "bounds": {
      "top": 0.7354920976688886,
      "left": 0.11764705392156861,
      "width": 0.21568627630718912,
      "height": 0.015151514520202022
    },
    "normalized_conf": 1,
    "engine": "pdftext"
  },
  {
    "text": "辉煌历程。",
    "bounds": {
